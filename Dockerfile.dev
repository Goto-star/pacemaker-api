# syntax=docker/dockerfile:1

# Development-only Dockerfile. The production image is built from ./Dockerfile.
# Keep RUBY_VERSION in sync with .ruby-version.
ARG RUBY_VERSION=3.3.11
FROM docker.io/library/ruby:$RUBY_VERSION-slim

# Rails app lives here
WORKDIR /rails

# Install packages needed to build gems and run the app in development.
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential \
      curl \
      git \
      libpq-dev \
      libvips \
      libyaml-dev \
      pkg-config \
      postgresql-client && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

ENV RAILS_ENV="development" \
    BUNDLE_PATH="/usr/local/bundle"

# Install gems first so the layer is cached unless the Gemfile changes.
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy the rest of the application code.
COPY . .

EXPOSE 3000

CMD ["bin/rails", "server", "-b", "0.0.0.0", "-p", "3000"]
